---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Etiqueta de Envío">
    <main class="flex-1 flex flex-col items-center justify-center p-4 md:p-8 no-print">
        <div class="w-full max-w-5xl space-y-6">
            <!-- Alert bar (only if needed) -->
            <div id="gateBox" class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/5 px-6 py-3 text-xs font-bold text-rose-400 backdrop-blur-xl transition-all">
                <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span>Sesión inactiva. Identifícate en <a href="/" class="underline hover:text-white">Inicio</a>.</span>
                </div>
            </div>

            <!-- Top Search Bar -->
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center">
                <div class="flex-1 relative group">
                    <input 
                        type="text" 
                        id="buscarCliente" 
                        placeholder="Buscar por nombre, código..." 
                        class="w-full rounded-2xl border border-white/10 bg-white/5 px-6 py-4 text-sm text-white outline-none transition-all focus:border-white/30 focus:bg-white/10 focus:ring-4 focus:ring-white/5 placeholder:text-slate-500" 
                    />
                    <div id="listaSugerencias" class="absolute left-0 right-0 top-[calc(100%+8px)] z-50 hidden max-h-64 overflow-auto rounded-3xl border border-white/10 bg-black/80 backdrop-blur-3xl shadow-2xl p-2 liquid-glass"></div>
                </div>

                <button class="inline-flex items-center justify-center gap-3 rounded-2xl bg-white text-black px-8 py-4 text-[10px] font-black uppercase tracking-widest transition hover:bg-slate-200 active:scale-95 shadow-lg shadow-white/5" type="button" id="printBtn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
                    Imprimir Etiqueta
                </button>
            </div>

            <!-- Main Label Component - Viewport Fit -->
            <section class="premium-card p-8 lg:p-12 relative overflow-hidden flex flex-col gap-8 md:gap-12">
                <!-- Inner Glow for the card head -->
                <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 blur-3xl pointer-events-none"></div>

                <header class="flex items-center justify-between border-b border-white/5 pb-8">
                    <!-- Logo without invert -->
                    <img src="/logo.png" class="h-14 w-auto object-contain transition-opacity hover:opacity-80" alt="Logo" />
                    <div class="hidden sm:block rounded-full border border-white/20 bg-white/5 px-5 py-2 text-[9px] font-black uppercase tracking-[0.3em] text-white">Envío Prioritario</div>
                </header>

                <div class="grid gap-6 md:gap-10 lg:grid-cols-2">
                    <div class="rounded-3xl border border-white/5 bg-white/[0.02] p-8 flex flex-col justify-center">
                        <span class="mb-4 block text-[9px] font-black uppercase tracking-[0.4em] text-slate-500">Remitente</span>
                        <div id="screenRemitente" class="text-sm md:text-base leading-relaxed text-slate-400 font-medium outline-none focus:text-white transition-colors" contenteditable="true">
                            <span class="mb-2 block text-2xl font-black tracking-tight text-white">DREAM.</span>
                            Repuestos Maranata<br />
                            SPS Cel # 3252-6432
                        </div>
                    </div>

                    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 shadow-inner shadow-white/5">
                        <span class="mb-4 block text-[9px] font-black uppercase tracking-[0.4em] text-slate-500">Destinatario</span>
                        <div id="nombreDest" class="mb-4 text-3xl font-black tracking-tight text-white leading-tight min-h-[1.2em]">Nombre del cliente</div>
                        <div class="space-y-3">
                            <div id="telDest" class="text-white/80 flex items-center gap-3 text-lg font-bold italic">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                <span>Cel: 0000-0000</span>
                            </div>
                            <div id="dirDest" class="text-slate-400 font-medium leading-relaxed text-base line-clamp-3">Ubicación de entrega cargada desde el directorio.</div>
                        </div>
                        <div id="statusLine" class="mt-8 min-h-6 text-[10px] font-black tracking-widest uppercase py-1 px-3 rounded-md bg-white/5 w-fit border border-white/5 opacity-0 transition-opacity"></div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <!-- Hidden Print Layer (DO NOT TOUCH AS REQUESTED) -->
    <section class="print-sheet">
        <div class="etiqueta">
            <div class="encabezado">
                <img src="/logo.png" class="logo" alt="Logo" />
                <div class="prioridad">ENVIO PRIORITARIO</div>
            </div>

            <div class="contenido-print">
                <div class="seccion-print">
                    <span class="label-print">REMITENTE</span>
                    <div id="printRemitente" class="valor-print remitente-nombre"></div>
                </div>

                <div class="seccion-print">
                    <span class="label-print">DESTINATARIO</span>
                    <div class="valor-print">
                        <div class="nombre-destinatario-print" id="printNombreDest">Nombre del Cliente</div>
                        <div class="detalles-destinatario-print">
                            <div class="telefono-print">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="phone-icon-print"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> 
                                <span id="printTelDest">Cel: 0000-0000</span>
                            </div>
                            <div class="direccion-print" id="printDirDest">Direccion de envio del cliente</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <style is:global>
        .print-sheet { display: none; }
        
        @media print {
            @page { size: landscape; margin: 5mm; }
            html, body { background: white !important; margin: 0 !important; width: 100% !important; overflow: visible !important; height: auto !important; }
            
            /* Hide layout elements tagged as no-print */
            .no-print { display: none !important; }
            
            /* Ensure the print container and sheet are visible */
            .print-container { display: block !important; padding: 0 !important; margin: 0 !important; border: 0 !important; background: white !important; }
            .print-sheet { 
                display: block !important; 
                width: 100% !important; 
                padding: 10mm !important; 
            }
            .etiqueta { width: 100%; background: #fff; color: #000 !important; }
            .encabezado { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
            .logo { height: 80px; }
            .prioridad { font-size: 12px; font-weight: 900; border: 2px solid #000; padding: 8px 20px; border-radius: 99px; text-transform: uppercase; color: #000 !important; }
            .seccion-print { border: 2.5px solid #000; padding: 25px 35px; border-radius: 25px; margin-bottom: 20px; color: #000 !important; }
            .label-print { display: block; font-size: 16px; font-weight: 900; margin-bottom: 12px; color: #000 !important; }
            .remitente-nombre { font-size: 32px; font-weight: 900; color: #000 !important; }
            .nombre-destinatario-print { font-size: 42px; font-weight: 900; line-height: 1.1; margin-bottom: 15px; color: #000 !important; }
            .detalles-destinatario-print { font-size: 26px; line-height: 1.4; color: #000 !important; }
            .telefono-print { font-weight: 900; display: flex; align-items: center; gap: 12px; color: #000 !important; }
            .direccion-print { font-weight: 600; white-space: pre-line; color: #000 !important; }
        }
    </style>

    <script>
        let clientsDatabase: any[] = [];
        let selectedClient: any = null;
        let sessionData: any = null;

        const inputBuscar = document.getElementById('buscarCliente') as HTMLInputElement;
        const listaSugerencias = document.getElementById('listaSugerencias') as HTMLDivElement;
        const nombreDest = document.getElementById('nombreDest') as HTMLDivElement;
        const telDest = document.getElementById('telDest') as HTMLDivElement;
        const dirDest = document.getElementById('dirDest') as HTMLDivElement;
        const screenRemitente = document.getElementById('screenRemitente') as HTMLDivElement;
        const statusLine = document.getElementById('statusLine') as HTMLDivElement;
        const printBtn = document.getElementById('printBtn') as HTMLButtonElement;
        const gateBox = document.getElementById('gateBox') as HTMLDivElement;

        // Print elements sync
        function syncPrintTemplate() {
            const pNombre = document.getElementById('printNombreDest');
            const pTel = document.getElementById('printTelDest');
            const pDir = document.getElementById('printDirDest');
            const pRem = document.getElementById('printRemitente');

            if (pNombre) pNombre.textContent = nombreDest.textContent || 'Nombre del Cliente';
            if (pTel) pTel.textContent = telDest.textContent || 'Cel: 0000-0000';
            if (pDir) pDir.textContent = dirDest.textContent || 'Direccion de envio del cliente';
            if (pRem) pRem.innerHTML = screenRemitente.innerHTML;
        }

        async function init() {
            const resp = await fetch('/api/session');
            const data = await resp.json();
            sessionData = data.session;

            if (!sessionData?.name) {
                gateBox.classList.remove('hidden');
                inputBuscar.disabled = true;
                printBtn.disabled = true;
                return;
            }

            screenRemitente.addEventListener('input', syncPrintTemplate);
            await fetchClientes();
        }

        async function fetchClientes() {
            const resp = await fetch('/api/clientes');
            const data = await resp.json();
            clientsDatabase = data.clients || [];
        }

        function selectClient(client: any) {
            selectedClient = client;
            nombreDest.textContent = client.nombre || client.name;
            telDest.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> <span>Cel: ${client.celular || client.phone}</span>`;
            dirDest.textContent = client.direccion || client.address;
            
            statusLine.textContent = `LISTO: ${client.nombre || client.name}`;
            statusLine.classList.remove('opacity-0');
            statusLine.classList.add('text-white', 'border-white/20');
            
            inputBuscar.value = '';
            listaSugerencias.classList.add('hidden');
            syncPrintTemplate();
        }

        inputBuscar.addEventListener('input', function() {
            const text = this.value.toLowerCase().trim();
            listaSugerencias.innerHTML = '';
            if (!text) { listaSugerencias.classList.add('hidden'); return; }

            const filtered = clientsDatabase.filter(c => 
                (c.nombre || '').toLowerCase().includes(text) || 
                (c.codigo || '').toLowerCase().includes(text)
            );

            if (filtered.length === 0) { listaSugerencias.classList.add('hidden'); return; }

            listaSugerencias.classList.remove('hidden');
            filtered.slice(0, 6).forEach(c => {
                const b = document.createElement('button');
                b.className = 'w-full flex items-center justify-between p-4 rounded-2xl hover:bg-white/10 transition-colors text-left group';
                b.innerHTML = `
                    <div>
                        <div class="text-sm font-bold text-white">${c.nombre}</div>
                        <div class="text-[9px] uppercase tracking-widest text-slate-500">${c.codigo || 'S/C'}</div>
                    </div>
                    <div class="text-[10px] font-black text-slate-400">${c.celular || 'S/N'}</div>
                `;
                b.onclick = () => selectClient(c);
                listaSugerencias.appendChild(b);
            });
        });

        printBtn.onclick = async () => {
            if (!selectedClient) {
                window.showToast({ message: 'Selecciona un cliente para imprimir', type: 'error' });
                return;
            }
            
            const msg = `${sessionData.name} sacó machote de ${selectedClient.nombre} | ${new Date().toLocaleString()}`;
            await fetch('/api/logs', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: msg })
            });

            window.print();
        };

        document.addEventListener('click', (e) => {
            if (!(e.target as any).closest('#buscarCliente') && !(e.target as any).closest('#listaSugerencias')) {
                listaSugerencias.classList.add('hidden');
            }
        });

        init();
    </script>
</Layout>
