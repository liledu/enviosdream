---
import Layout from '../layouts/Layout.astro';
import { getSessionUserFromCookies, toStaffSession } from '../lib/auth';

const user = await getSessionUserFromCookies(Astro.cookies);

if (!user) {
    return Astro.redirect('/');
}

const session = toStaffSession(user);
const isAdmin = session.email === 'eduardocastroc1@gmail.com';
---

<Layout title="Administración | Machote">
    <main class="flex-1 flex flex-col items-center justify-center p-4 md:p-6 w-full max-w-6xl mx-auto overflow-hidden">
        {!isAdmin ? (
            <div class="text-center space-y-8 animate-in fade-in zoom-in duration-500">
                <div class="w-24 h-24 rounded-full bg-rose-500/10 border border-rose-500/20 text-rose-500 flex items-center justify-center mx-auto shadow-2xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m14.5 9-5 5"/><path d="m9.5 9 5 5"/></svg>
                </div>
                <div>
                    <h1 class="text-3xl font-black tracking-tight text-white uppercase tracking-[0.2em]">Acceso Denegado</h1>
                    <p class="text-slate-500 mt-4 text-[10px] font-bold uppercase tracking-widest leading-relaxed">Esta sección está reservada exclusivamente para el Comandante Maestro.</p>
                </div>
                <a href="/machote" class="inline-block py-4 px-10 rounded-2xl bg-white text-black text-[10px] font-black uppercase tracking-widest transition hover:bg-slate-200 active:scale-95 shadow-xl shadow-white/5">
                    Volver al Dashboard
                </a>
            </div>
        ) : (
            <>
        <header class="mb-6 text-center relative w-full">
            <div class="absolute inset-0 bg-white/5 blur-[80px] -z-10 rounded-full"></div>
            
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white text-black mb-4 shadow-2xl transition-transform hover:scale-105 active:scale-95 duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            
            <h1 class="text-2xl font-black tracking-tight text-white uppercase italic">Configuración Admin</h1>
            <p class="text-slate-500 mt-1 text-[8px] font-black uppercase tracking-[0.3em] font-mono">{session.email}</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 w-full items-start">

            <!-- Section 1: My Profile -->
            <section class="premium-card p-6 flex flex-col space-y-6 relative overflow-hidden h-fit">
                <div class="absolute bottom-0 right-0 w-32 h-32 bg-purple-500/5 blur-[80px] pointer-events-none"></div>

                <div class="border-b border-white/5 pb-4">
                    <h2 class="text-xs font-black tracking-widest text-white uppercase italic">Identidad Digital</h2>
                </div>

                <div class="space-y-4">
                    <div>
                        <label for="fullName" class="mb-2 block text-[8px] font-black uppercase tracking-[0.4em] text-slate-500">Nombre del Comandante</label>
                        <input type="text" id="fullName" value={session.name} class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white outline-none focus:border-white/30 transition-all focus:bg-white/10 font-medium" />
                    </div>
                </div>

                <div class="flex flex-col gap-3 pt-4 border-t border-white/5">
                    <button id="updateBtn" class="w-full py-3 rounded-xl bg-white text-black text-[9px] font-black uppercase tracking-widest transition hover:bg-slate-200 active:scale-95">Guardar Perfil</button>
                    <a href="/api/auth/signout" class="w-full py-3 rounded-xl bg-rose-500/5 text-rose-500 text-[9px] font-black uppercase tracking-widest transition hover:bg-rose-500/10 text-center border border-rose-500/10 active:scale-95">Cerrar Sesión</a>
                </div>

                <div id="statusMsg" class="text-center min-h-[12px] text-[8px] font-black uppercase tracking-widest opacity-0 transition-opacity"></div>
            </section>

            <section class="premium-card p-4 space-y-4 relative overflow-hidden h-fit">
                <div class="absolute bottom-0 right-0 w-24 h-24 bg-purple-500/5 blur-[60px] pointer-events-none"></div>

                <div class="border-b border-white/5 pb-3">
                    <h2 class="text-[10px] font-black tracking-widest text-white uppercase italic">Gestión de Operadores</h2>
                </div>

                <form id="regForm" class="space-y-3">
                    <div>
                        <label for="regEmail" class="mb-1 block text-[7px] font-black uppercase tracking-[0.2em] text-slate-500">Email Operador</label>
                        <input type="email" id="regEmail" placeholder="correo@ejemplo.com" required class="w-full rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs text-white outline-none focus:border-white/30 transition-all focus:bg-white/10" />
                    </div>
                    <div>
                        <label for="regPass" class="mb-1 block text-[7px] font-black uppercase tracking-[0.2em] text-slate-500">Contraseña</label>
                        <input type="password" id="regPass" placeholder="••••••••" required class="w-full rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs text-white outline-none focus:border-white/30 transition-all focus:bg-white/10" />
                    </div>
                    <div>
                        <label for="regName" class="mb-1 block text-[7px] font-black uppercase tracking-[0.2em] text-slate-500">Nombre Completo</label>
                        <input type="text" id="regName" placeholder="Nombre Apellido" required class="w-full rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs text-white outline-none focus:border-white/30 transition-all focus:bg-white/10" />
                    </div>
                    
                    <button type="submit" id="regBtn" class="w-full py-3 rounded-lg bg-white text-black text-[9px] font-black uppercase tracking-widest transition hover:bg-slate-200 active:scale-95 shadow-xl shadow-white/5">Registrar Operador Noir</button>
                    <div id="regStatus" class="text-center min-h-[10px] text-[7px] font-black uppercase tracking-widest opacity-0 transition-opacity"></div>
                </form>
            </section>
        </div>

        <footer class="mt-4 text-center text-slate-600 text-[8px] font-black uppercase tracking-widest">
            Machote v4.0 Noir Edition
        </footer>
            </>
        )}
    </main>

    <script>
        const updateBtn = document.getElementById('updateBtn') as HTMLButtonElement;
        const fullNameInput = document.getElementById('fullName') as HTMLInputElement;
        const statusMsg = document.getElementById('statusMsg');

        updateBtn?.addEventListener('click', async () => {
            const fullName = fullNameInput.value.trim();
            if (!fullName) return;

            updateBtn.textContent = 'GUARDANDO...';
            updateBtn.disabled = true;
            statusMsg!.textContent = 'Procesando cambios...';
            statusMsg!.className = 'text-center min-h-6 text-[9px] font-black uppercase tracking-widest text-slate-500 opacity-100 animate-pulse';

            try {
                const response = await fetch('/api/profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName })
                });

                if (response.ok) {
                    statusMsg!.textContent = '✓ Perfil Actualizado';
                    statusMsg!.className = 'text-center min-h-6 text-[9px] font-black uppercase tracking-widest text-emerald-500 opacity-100';
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    throw new Error('Error');
                }
            } catch (err) {
                statusMsg!.textContent = '✕ Error de Sincronización';
                statusMsg!.className = 'text-center min-h-6 text-[9px] font-black uppercase tracking-widest text-rose-500 opacity-100';
            } finally {
                updateBtn.textContent = 'GUARDAR CAMBIOS';
                updateBtn.disabled = false;
            }
        });

        // Lógica de Registro
        const regForm = document.getElementById('regForm') as HTMLFormElement;
        const regStatus = document.getElementById('regStatus');
        const regBtn = document.getElementById('regBtn') as HTMLButtonElement;

        regForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = (document.getElementById('regEmail') as HTMLInputElement).value;
            const password = (document.getElementById('regPass') as HTMLInputElement).value;
            const fullName = (document.getElementById('regName') as HTMLInputElement).value;

            if (regBtn) {
                regBtn.textContent = 'PROCESANDO...';
                regBtn.disabled = true;
            }
            
            if (regStatus) {
                regStatus.textContent = 'Creando cuenta...';
                regStatus.className = 'text-center min-h-6 text-[9px] font-black uppercase tracking-widest text-slate-500 opacity-100 animate-pulse';
            }

            try {
                const response = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password, fullName })
                });

                const data = await response.json();

                if (response.ok) {
                    if (regStatus) {
                        regStatus.textContent = '✓ Registro Exitoso';
                        regStatus.className = 'text-center min-h-6 text-[9px] font-black uppercase tracking-widest text-emerald-500 opacity-100';
                    }
                    regForm.reset();
                } else {
                    throw new Error(data.message || 'Error de registro');
                }
            } catch (err: any) {
                if (regStatus) {
                    regStatus.textContent = `✕ ${err.message}`;
                    regStatus.className = 'text-center min-h-6 text-[9px] font-black uppercase tracking-widest text-rose-500 opacity-100';
                }
            } finally {
                if (regBtn) {
                    regBtn.textContent = 'REGISTRAR OPERADOR NOIR';
                    regBtn.disabled = false;
                }
            }
        });
    </script>
</Layout>
